# Direct backend (pyOCD/FastAPI) - default recommended mode
VITE_WS_DIRECT_URL=ws://localhost:8765/ws
VITE_API_URL=http://localhost:8765

# Optional legacy Node-RED/CubeMonitor fallback
VITE_ENABLE_NODERED_FALLBACK=false
VITE_WS_NODERED_URL=ws://localhost:1880/ws/stm32

# Optional override list head (normally can be left empty)
# VITE_WS_URL=

# Optional backend symbol addresses (if firmware relink changes RAM layout)
# Use in backend process environment before running server.py
# LED_STATUS_ADDR=0x200000bc
# MODE_ADDR=0x200000b8
# VAR1_ADDR=0x200000c4
# VAR1_TYPE=int
# ADC_VALUE_ADDR=0x200000cc
# EXTI_FLAG_ADDR=0x200000d0
